---
import { type Paper } from '../lib/data';

interface Props {
  paper: Paper;
}

const { paper } = Astro.props;

function joinList(values: string[], fallback = 'Not listed'): string {
  return values.length ? values.join('; ') : fallback;
}

function shortList(values: string[], max = 1, fallback = 'Not listed'): string {
  if (!values.length) return fallback;
  const visible = values.slice(0, max).join('; ');
  const hidden = values.length - max;
  return hidden > 0 ? `${visible} +${hidden}` : visible;
}

const tracks = paper.tracks.slice(0, 4);
const extraTracks = paper.tracks.length - tracks.length;

const searchText = [
  paper.id,
  paper.title,
  paper.abstract,
  paper.eventType,
  paper.authorInstitutions,
  ...paper.authors,
  ...paper.tracks,
  ...paper.sessionTitles,
  ...paper.locations,
].join(' ').toLowerCase();
---

<article
  class="paper-card"
  data-id={paper.id}
  data-search={searchText}
  data-tracks={paper.tracks.join('||')}
  data-sort-title={paper.title.toLowerCase()}
  data-sort-author={(paper.authors[0] ?? '').toLowerCase()}
>
  <div class="card-top">
    <div class="title-block">
      <div class="paper-id">{paper.id}</div>
      <h2 class="paper-title">{paper.title}</h2>
      <p class="paper-authors">{joinList(paper.authors)}</p>
    </div>
  </div>

  <button
    class="icon-button favorite-button"
    type="button"
    data-fav-id={paper.id}
    aria-pressed="false"
    aria-label="Save to favorites"
    title="Save to favorites"
  >☆</button>

  <div class="compact-meta">
    <span class="meta-item" title={joinList(paper.dates)}>
      <strong>Date:</strong>{shortList(paper.dates)}
    </span>
    <span class="meta-item" title={joinList(paper.locations)}>
      <strong>Location:</strong>{shortList(paper.locations)}
    </span>
    <span class="meta-item" title={joinList(paper.sessionTitles)}>
      <strong>Session:</strong>{shortList(paper.sessionTitles)}
    </span>
  </div>

  {paper.abstract && (
    <details class="paper-abstract">
      <summary>Abstract</summary>
      <p>{paper.abstract}</p>
    </details>
  )}

  {paper.tracks.length > 0 && (
    <div class="chips">
      {tracks.map((track) => <span class="chip">{track}</span>)}
      {extraTracks > 0 && <span class="chip">+{extraTracks} more</span>}
    </div>
  )}

  {paper.urls[0] && (
    <a
      class="icon-button program-link"
      href={paper.urls[0]}
      target="_blank"
      rel="noreferrer"
      title="Open program page"
      aria-label="Open program page"
    >↗</a>
  )}
</article>
