---
import { execSync } from 'node:child_process';
import Layout from '../layouts/Layout.astro';
import { loadVenues, groupByCategory, totalPaperCount, loadGeneratedAt } from '../lib/data';
import '../styles/global.css';

const venues = loadVenues();
const groups = groupByCategory(venues);
const totalPapers = totalPaperCount(venues);

// Build-time provenance for the sidebar footer.
const REPO_URL = 'https://github.com/superpung/confer';
let commit = process.env.COMMIT_REF ?? '';
if (!commit) {
  try { commit = execSync('git rev-parse HEAD').toString().trim(); } catch { commit = ''; }
}
const shortHash = commit ? commit.slice(0, 7) : '';
const commitUrl = commit ? `${REPO_URL}/commit/${commit}` : REPO_URL;

const generatedAt = loadGeneratedAt();
const updatedLabel = generatedAt
  ? new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(new Date(generatedAt))
  : null;
// Exact timestamp for the footer's native hover tooltip (relative time is filled in by JS).
const builtExact = generatedAt
  ? new Intl.DateTimeFormat('en-US', { dateStyle: 'medium', timeStyle: 'medium' }).format(new Date(generatedAt))
  : null;
const year = new Date().getFullYear();
---

<Layout title="confer - where research convenes">
  <div class="app" id="app">
    <!-- Embedded manifest for the client app. -->
    <script type="application/json" id="venues-data" set:html={JSON.stringify(venues)} />

    <aside class="sidebar" id="sidebar" aria-label="Venue selector">
      <div class="sidebar-head">
        <a class="brand" href="/">
          <svg class="brand-mark" viewBox="0 0 32 32" aria-hidden="true"><rect width="32" height="32" rx="7" fill="#c96442"/><text x="16" y="23" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="22" font-weight="600" fill="#faf9f5">c</text></svg>
          <span>confer</span>
        </a>
        <div class="sidebar-head-actions">
          <button class="icon-btn" data-theme-toggle title="Toggle theme" aria-label="Toggle theme">
            <span data-theme-icon><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg></span>
          </button>
          <button class="icon-btn sidebar-collapse-btn" data-sidebar-collapse title="Collapse sidebar" aria-label="Collapse sidebar"><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg></button>
        </div>
      </div>

      <p class="sidebar-stats" id="sidebarStats">
        {venues.length} venues · {totalPapers.toLocaleString()} papers
      </p>

      <div class="venue-tools">
        <input class="venue-search" type="search" placeholder="Filter venues…" data-venue-search aria-label="Filter venues" />
        <div class="venue-tool-buttons">
          <button class="text-btn" data-select-all type="button">All</button>
          <button class="text-btn" data-select-none type="button">None</button>
        </div>
      </div>

      <nav class="venue-nav" aria-label="Venues">
        {groups.length === 0 && <p class="venue-empty">No venues yet.</p>}
        {groups.map((group) => (
          <section class="venue-cat" data-cat={group.category}>
            <button class="venue-cat-head" type="button" data-cat-toggle aria-expanded="true">
              <span class="cat-caret">▾</span>
              <span class="cat-name">{group.category}</span>
              <span class="cat-count">{group.count.toLocaleString()}</span>
            </button>
            <div class="venue-cat-body">
              <div class="venue-cat-inner">
                {[
                  { label: 'Conferences', items: group.conferences },
                  { label: 'Journals', items: group.journals },
                ].filter((s) => s.items.length > 0).map((sub) => (
                  <div class="venue-sub">
                    {group.conferences.length > 0 && group.journals.length > 0 && (
                      <p class="venue-sub-label">{sub.label}</p>
                    )}
                    {sub.items.map((venue) => (
                      <label
                        class="venue-row"
                        data-venue-row
                        data-venue-name={`${venue.name} ${venue.series}`.toLowerCase()}
                      >
                        <input class="venue-check" type="checkbox" value={venue.id} data-venue-check />
                        <span class="venue-row-name">{venue.name}</span>
                        <span class={`venue-kind kind-${venue.kind}`}>{venue.kind === 'journal' ? 'J' : 'C'}</span>
                        <span class="venue-row-count">{venue.count.toLocaleString()}</span>
                      </label>
                    ))}
                  </div>
                ))}
              </div>
            </div>
          </section>
        ))}
      </nav>

      <footer class="sidebar-foot">
        <p class="foot-meta">
          <a class="foot-gh" href={REPO_URL} target="_blank" rel="noreferrer" title="Source on GitHub" aria-label="Source on GitHub">
            <svg viewBox="0 0 16 16" width="15" height="15" aria-hidden="true" fill="currentColor">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
            </svg>
          </a>
          {shortHash && (
            <a class="foot-hash" href={commitUrl} target="_blank" rel="noreferrer" title="View this commit">{shortHash}</a>
          )}
          {shortHash && generatedAt && <span class="foot-sep" aria-hidden="true">·</span>}
          {generatedAt && (
            <time class="foot-built" datetime={generatedAt} title={builtExact} data-built>Built {updatedLabel}</time>
          )}
        </p>
        <p class="foot-copy">Copyright © {year} <a href="https://github.com/superpung" target="_blank" rel="noreferrer">Super Lee</a> &amp; <a href="https://claude.com/product/claude-code" target="_blank" rel="noreferrer">Claude</a></p>
      </footer>
    </aside>

    <div class="sidebar-scrim" id="sidebarScrim"></div>

    <main class="content" id="content">
      <header class="topbar">
        <button class="icon-btn sidebar-toggle" data-sidebar-toggle aria-label="Show venues"><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
        <div class="search-wrap">
          <span class="search-icon" aria-hidden="true"><svg class="ic" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>
          <input id="searchInput" class="global-search" type="search"
            placeholder="Search… try author: title: inst:" aria-label="Search papers" />
          <kbd class="search-kbd">⌘K</kbd>
          <button class="search-clear" data-search-clear aria-label="Clear search" hidden><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
        </div>
        <select id="sortSelect" class="topbar-select" aria-label="Sort">
          <option value="venue">Sort: Venue</option>
          <option value="id">Sort: Paper ID</option>
          <option value="title">Sort: Title</option>
          <option value="authors">Sort: Authors</option>
        </select>
        <button class="icon-btn" data-help title="Keyboard shortcuts (⌘/)" aria-label="Keyboard shortcuts"><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 3a3 3 0 0 0-3 3v12a3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3H6a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3V6a3 3 0 0 0-3-3 3 3 0 0 0-3 3 3 3 0 0 0 3 3h12a3 3 0 0 0 3-3 3 3 0 0 0-3-3z"/></svg></button>
        <button class="icon-btn rail-toggle" data-rail-toggle title="Show insights" aria-label="Show insights"><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><line x1="6" y1="20" x2="6" y2="14"/><line x1="12" y1="20" x2="12" y2="9"/><line x1="18" y1="20" x2="18" y2="4"/></svg></button>
      </header>

      <div class="controls">
        <button class="chip-btn" data-facets-toggle type="button" aria-expanded="false">
          <span>Filters</span><span class="chip-btn-count" id="facetActiveCount" hidden>0</span>
        </button>
        <label class="fav-toggle">
          <input type="checkbox" id="favOnly" />
          <span class="favlabel"><svg class="ic ic--sm" viewBox="0 0 24 24" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>Only favorites</span>
        </label>
        <button class="chip-btn" data-open-saved type="button"><svg class="ic ic--sm" viewBox="0 0 24 24" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>Saved</button>
        <div class="result-summary" id="resultSummary">Select a venue to begin.</div>
      </div>

      <div class="active-filters" id="activeFilters"></div>
      <div class="facets-wrap" id="facetsWrap">
        <div class="facets-clip">
          <section class="facets" id="facets" aria-label="Filters"></section>
        </div>
      </div>

      <div class="export-bar" id="exportBar" hidden>
        <span id="selCount">0 selected</span>
        <div class="export-actions">
          <button class="text-btn" data-export="bibtex" type="button">Copy BibTeX</button>
          <button class="text-btn" data-export="csv" type="button">Download CSV</button>
          <button class="text-btn" data-export="clear" type="button">Clear</button>
        </div>
      </div>

      <section class="paper-list" id="paperList" aria-live="polite"></section>
      <div class="list-more" id="listMore" hidden></div>
    </main>

    <aside class="rail" id="rail" aria-label="Insights">
      <div class="rail-head">
        <span class="rail-title">Insights</span>
        <button class="icon-btn rail-collapse-btn" data-rail-collapse title="Hide insights" aria-label="Hide insights"><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg></button>
      </div>
      <p class="rail-note">Live stats for the papers in view. Click a bar to filter.</p>
      <div class="rail-body" id="railBody"></div>
    </aside>

    <button class="back-to-top" id="backToTop" aria-label="Back to top" hidden><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg></button>
    <div class="toast" id="toast" role="status" hidden></div>

    <div class="modal" id="helpModal" hidden>
      <div class="modal-card" role="dialog" aria-modal="true" aria-label="Help">
        <div class="modal-head"><h2>Search &amp; shortcuts</h2><button class="icon-btn" data-modal-close aria-label="Close"><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
        <h3 class="modal-subhead">Search fields</h3>
        <p class="modal-hint">Prefix a term to scope it; combine terms (all must match); quote phrases.</p>
        <dl class="shortcuts">
          <div><dt><code>author:</code></dt><dd>Match authors — <code>author:"Jane Doe"</code></dd></div>
          <div><dt><code>title:</code></dt><dd>Match the title — <code>title:routing</code></dd></div>
          <div><dt><code>inst:</code></dt><dd>Match institutions — <code>inst:"MIT"</code></dd></div>
          <div><dt><code>track:</code></dt><dd>Match a track / topic</dd></div>
          <div><dt><code>abstract:</code></dt><dd>Match abstract text</dd></div>
          <div><dt><code>doi:</code></dt><dd>Match DOI metadata</dd></div>
          <div><dt><code>keyword:</code></dt><dd>Match indexed keywords / concepts</dd></div>
          <div><dt><code>container:</code></dt><dd>Match journal or proceedings metadata</dd></div>
          <div><dt>plain text</dt><dd>Matches anything</dd></div>
        </dl>
        <h3 class="modal-subhead">Keyboard</h3>
        <dl class="shortcuts">
          <div><dt><kbd>⌘</kbd><kbd>K</kbd></dt><dd>Focus search</dd></div>
          <div><dt><kbd>Esc</kbd></dt><dd>Clear search / close</dd></div>
          <div><dt><kbd>⌘</kbd><kbd>/</kbd></dt><dd>Toggle this panel</dd></div>
          <div><dt><kbd>f</kbd></dt><dd>Toggle filters</dd></div>
        </dl>
      </div>
    </div>

    <div class="modal" id="savedModal" hidden>
      <div class="modal-card" role="dialog" aria-modal="true" aria-label="Saved searches">
        <div class="modal-head"><h2>Saved searches</h2><button class="icon-btn" data-modal-close aria-label="Close"><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
        <div class="modal-actions"><button class="text-btn btn-ico" data-save-current type="button"><svg class="ic ic--sm" viewBox="0 0 24 24" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Save current view</button></div>
        <div id="savedList" class="saved-list"></div>
      </div>
    </div>
  </div>

  <script src="../scripts/app.ts"></script>
</Layout>
