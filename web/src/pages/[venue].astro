---
import Base from '../layouts/Base.astro';
import PaperCard from '../components/PaperCard.astro';
import { loadVenues, loadPapers, venueTracks, type VenueSummary, type Paper } from '../lib/data';

export async function getStaticPaths() {
  const venues = loadVenues();
  return venues.map((venue) => {
    const papers = loadPapers(venue.id);
    return {
      params: { venue: venue.id },
      props: { venue, venues, papers, tracks: venueTracks(papers) },
    };
  });
}

interface Props {
  venue: VenueSummary;
  venues: VenueSummary[];
  papers: Paper[];
  tracks: string[];
}

const { venue, venues, papers, tracks } = Astro.props;
const kindLabel = venue.kind === 'journal' ? 'Journal' : 'Conference';
---

<Base title={`${venue.name} · confcrawl`} venues={venues} activeId={venue.id}>
  <div class="page-shell">
    <section class="page-intro">
      <p class="eyebrow">{kindLabel}{venue.year ? ` · ${venue.year}` : ''}</p>
      <h1>{venue.name}</h1>
      <p class="intro-copy">
        Search by title, author, abstract, track, or session. Favorites are saved locally
        in your browser.
      </p>
    </section>

    <section class="toolbar" aria-label="Paper filters">
      <label class="search-box">
        <span>Search</span>
        <input id="searchInput" type="search" placeholder="Timing analysis, GPU, security…" />
      </label>
      <label>
        <span>Track</span>
        <select id="trackFilter">
          <option value="">All tracks</option>
          {tracks.map((track) => <option value={track}>{track}</option>)}
        </select>
      </label>
      <label>
        <span>Sort</span>
        <select id="sortSelect">
          <option value="id">Paper ID</option>
          <option value="title">Title</option>
          <option value="authors">Authors</option>
        </select>
      </label>
    </section>

    <div class="toolbar-extra">
      <label class="fav-toggle">
        <input id="favOnly" type="checkbox" />
        <span>Only favorites</span>
      </label>
    </div>

    <div class="result-summary" id="resultSummary">{papers.length} papers</div>

    <section class="paper-grid" id="paperGrid" data-venue={venue.id} aria-live="polite">
      {papers.map((paper) => <PaperCard paper={paper} />)}
    </section>
  </div>
</Base>

<script>
  const FAV_KEY = 'confcrawl.favorites';
  const grid = document.getElementById('paperGrid') as HTMLElement;
  const venueId = grid.dataset.venue ?? '';
  const cards = Array.from(grid.querySelectorAll<HTMLElement>('.paper-card'));
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const trackFilter = document.getElementById('trackFilter') as HTMLSelectElement;
  const sortSelect = document.getElementById('sortSelect') as HTMLSelectElement;
  const favOnly = document.getElementById('favOnly') as HTMLInputElement;
  const summary = document.getElementById('resultSummary') as HTMLElement;

  const favKey = (id: string) => `${venueId}:${id}`;

  function loadFavs(): Set<string> {
    try {
      const arr = JSON.parse(localStorage.getItem(FAV_KEY) || '[]');
      return new Set(Array.isArray(arr) ? arr : []);
    } catch {
      return new Set();
    }
  }
  const favs = loadFavs();

  function applyFavState() {
    for (const card of cards) {
      const btn = card.querySelector('.favorite-button') as HTMLButtonElement;
      const on = favs.has(favKey(card.dataset.id ?? ''));
      btn.setAttribute('aria-pressed', String(on));
      btn.textContent = on ? '★' : '☆';
      btn.title = on ? 'Remove from favorites' : 'Save to favorites';
      btn.setAttribute('aria-label', btn.title);
    }
  }

  function render() {
    const q = searchInput.value.trim().toLowerCase();
    const track = trackFilter.value;
    const onlyFav = favOnly.checked;
    let visible = 0;
    for (const card of cards) {
      let show = true;
      if (q && !(card.dataset.search ?? '').includes(q)) show = false;
      if (show && track && !(card.dataset.tracks ?? '').split('||').includes(track)) show = false;
      if (show && onlyFav && !favs.has(favKey(card.dataset.id ?? ''))) show = false;
      card.hidden = !show;
      if (show) visible++;
    }

    const key = sortSelect.value;
    const sorted = [...cards].sort((a, b) => {
      if (key === 'title') return (a.dataset.sortTitle ?? '').localeCompare(b.dataset.sortTitle ?? '');
      if (key === 'authors') return (a.dataset.sortAuthor ?? '').localeCompare(b.dataset.sortAuthor ?? '');
      return (a.dataset.id ?? '').localeCompare(b.dataset.id ?? '', undefined, { numeric: true });
    });
    for (const card of sorted) grid.appendChild(card);

    summary.textContent = `${visible} of ${cards.length} papers`;
  }

  grid.addEventListener('click', (event) => {
    const target = event.target as HTMLElement;
    const btn = target.closest('.favorite-button') as HTMLButtonElement | null;
    if (!btn) return;
    const card = btn.closest('.paper-card') as HTMLElement;
    const key = favKey(card.dataset.id ?? '');
    if (favs.has(key)) favs.delete(key);
    else favs.add(key);
    localStorage.setItem(FAV_KEY, JSON.stringify([...favs].sort()));
    applyFavState();
    if (favOnly.checked) render();
  });

  searchInput.addEventListener('input', render);
  trackFilter.addEventListener('change', render);
  sortSelect.addEventListener('change', render);
  favOnly.addEventListener('change', render);

  applyFavState();
  render();
</script>
