---
import Sidebar from '../components/Sidebar.astro';
import { type VenueSummary } from '../lib/data';
import '../styles/global.css';

interface Props {
  title: string;
  venues: VenueSummary[];
  activeId?: string;
}

const { title, venues, activeId } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&display=swap"
    />
  </head>
  <body>
    <div class="layout">
      <Sidebar venues={venues} activeId={activeId} />
      <main class="content">
        <slot />
      </main>
    </div>
  </body>
</html>
